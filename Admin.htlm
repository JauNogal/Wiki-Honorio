<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Secreto - Wiki-Honorio</title>
    <script src="https://unpkg.com/xlsx/dist/xlsx.full.min.js"></script>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; padding: 20px; background-color: #f4f4f9; color: #333; }
        .container { max-width: 600px; margin: 40px auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); text-align: center; }
        h1 { color: #2c3e50; font-size: 1.8rem; margin-bottom: 10px; }
        p { color: #666; margin-bottom: 20px; }
        input[type="file"] { margin: 20px 0; padding: 10px; border: 2px dashed #ccc; border-radius: 8px; width: 100%; cursor: pointer; }
        .btn { background: #e74c3c; color: white; border: none; padding: 12px 25px; font-size: 1.1rem; cursor: pointer; border-radius: 8px; font-weight: bold; width: 100%; transition: background 0.3s; }
        .btn:hover { background: #c0392b; }
        #estado { margin-top: 25px; font-size: 1.1rem; font-weight: bold; padding: 15px; border-radius: 8px; display: none; }
        .info { background: #e3f2fd; color: #1565c0; }
        .exito { background: #e8f5e9; color: #2e7d32; }
        .error { background: #ffebee; color: #c62828; }
    </style>
</head>
<body>

    <div class="container">
        <h1>🛠️ Importador de Base de Datos</h1>
        <p>Sube tu archivo Excel (.xlsx) con las pestañas: <b>escuelas, sectores y vias</b>.</p>
        
        <input type="file" id="archivoExcel" accept=".xlsx, .xls">
        <button class="btn" onclick="procesarExcel()">Sincronizar con Firebase 🚀</button>
        
        <div id="estado"></div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getFirestore, doc, setDoc } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        // Tu configuración real de Firebase
        const firebaseConfig = {
            apiKey: "AIzaSyAKFD-lU2qwl_bnmhe9KGWBnlWWwhqx1W0",
            authDomain: "wiki-honorio.firebaseapp.com",
            projectId: "wiki-honorio",
            storageBucket: "wiki-honorio.firebasestorage.app",
            messagingSenderId: "544094917297",
            appId: "1:544094917297:web:f0e150ce0db1cfd7374890"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);

        function mostrarMensaje(texto, tipo) {
            const div = document.getElementById('estado');
            div.style.display = 'block';
            div.className = tipo;
            div.innerHTML = texto;
        }

        window.procesarExcel = async function() {
            // SEGURIDAD BÁSICA: Contraseña para que no lo use cualquiera que adivine el enlace
            const password = prompt("Introduce la clave de administrador:");
            if (password !== "honorio2024") {
                alert("Contraseña incorrecta.");
                return;
            }

            const input = document.getElementById('archivoExcel');
            if (!input.files.length) {
                mostrarMensaje("⚠️ Por favor, selecciona un archivo Excel primero.", "error");
                return;
            }

            mostrarMensaje("⏳ Leyendo archivo Excel... Por favor, espera.", "info");
            
            const file = input.files[0];
            const reader = new FileReader();

            reader.onload = async function(e) {
                try {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, {type: 'array'});

                    // Comprobar que las pestañas se llaman exactamente así
                    const hojas = workbook.SheetNames;
                    if (!hojas.includes('escuelas') || !hojas.includes('sectores') || !hojas.includes('vias')) {
                        mostrarMensaje("❌ Error: El Excel debe tener 3 pestañas llamadas exactamente: escuelas, sectores, vias (en minúsculas).", "error");
                        return;
                    }

                    mostrarMensaje("🚀 Subiendo datos a Firebase... No cierres esta ventana.", "info");

                    // 1. Subir Escuelas
                    const escuelas = XLSX.utils.sheet_to_json(workbook.Sheets['escuelas']);
                    for (let fila of escuelas) {
                        if(fila.id) await setDoc(doc(db, "escuelas", fila.id.toString()), fila);
                    }

                    // 2. Subir Sectores
                    const sectores = XLSX.utils.sheet_to_json(workbook.Sheets['sectores']);
                    for (let fila of sectores) {
                        if(fila.id) await setDoc(doc(db, "sectores", fila.id.toString()), fila);
                    }

                    // 3. Subir Vías
                    const vias = XLSX.utils.sheet_to_json(workbook.Sheets['vias']);
                    for (let fila of vias) {
                        if(fila.id) await setDoc(doc(db, "vias", fila.id.toString()), fila);
                    }

                    mostrarMensaje("✅ ¡Sincronización completada con éxito! Tu web ya está actualizada.", "exito");

                } catch (error) {
                    mostrarMensaje("❌ Error crítico durante la subida: " + error.message, "error");
                    console.error(error);
                }
            };

            reader.readAsArrayBuffer(file);
        }
    </script>
</body>
</html>